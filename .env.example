# API Keys (optional - required depending on LLM_PROVIDER)
OPENAI_API_KEY=sk-your-openai-api-key-here
GROQ_API_KEY=gsk_your-groq-api-key-here
TOGETHER_API_KEY=your-together-api-key-here
NVIDIA_API_KEY=nvapi-xxxxx

# LLM Configuration
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Index Paths
FAISS_INDEX_PATH=data/processed/faiss_index
BM25_INDEX_PATH=data/processed/bm25_index.pkl

# LangSmith (optional - for tracing and monitoring)
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=chipmind
LANGSMITH_TRACING=true
